# Copy to .env and fill in real values. .env is git-ignored.

# Generate with: openssl rand -hex 24
# Do NOT use APISIX's tutorial default key (edd1c9f034335f136f87ad84b625c8f) — it's public
# knowledge and grants full admin control (route/consumer/plugin management) if reachable.
APISIX_ADMIN_KEY=

# JWT signing key for portal login sessions. Generate with: openssl rand -hex 32
# core-api refuses to start if this is empty — see app/core/auth.py.
JWT_SECRET=

# BOT Exchange Rate API — not yet integrated (see README), placeholder for when it is.
BOT_API_TOKEN=

# TMD nwpapi Bearer token — register at data.tmd.go.th/nwpapi/register (valid ~1 year)
TMD_API_TOKEN=
