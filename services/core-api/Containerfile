FROM python:3.12-slim

RUN pip install --no-cache-dir uv

WORKDIR /app

# Shared package copied in first so its path dependency resolves, then core-api itself —
# ordered this way so the Podman layer cache only invalidates the shared install when
# shared/ actually changes, not on every core-api code edit.
COPY services/shared /app/shared
COPY services/core-api /app/core-api
COPY scripts /app/scripts

WORKDIR /app/core-api
RUN uv pip install --system .

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
